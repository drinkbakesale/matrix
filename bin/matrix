#!/usr/bin/env bash
set -euo pipefail

# matrix — Matrix session manager
# Manages tmux sessions with Claude Code
#
# Usage: matrix <command> [args]

MATRIX_HOME="${MATRIX_HOME:-$HOME/.matrix}"
CONF="${MATRIX_HOME}/projects.conf"
LOG_DIR="${MATRIX_HOME}/logs"
mkdir -p "$LOG_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ── Helpers ────────────────────────────────────────────────────────────

_err()  { echo -e "${RED}error:${NC} $*" >&2; }
_info() { echo -e "${BLUE}→${NC} $*"; }
_ok()   { echo -e "${GREEN}✓${NC} $*"; }
_warn() { echo -e "${YELLOW}⚠${NC} $*"; }

_require_conf() {
  if [[ ! -f "$CONF" ]]; then
    _err "No projects.conf found at $CONF"
    echo "  Run: matrix add <name> <path>"
    exit 1
  fi
}

# Read projects from conf, skip comments and blanks
_read_projects() {
  grep -v '^\s*#' "$CONF" 2>/dev/null | grep -v '^\s*$' || true
}

_get_project() {
  local name="$1"
  _read_projects | grep "^${name}|" || true
}

# ── Commands ───────────────────────────────────────────────────────────

cmd_up() {
  local target="${1:-all}"
  _require_conf

  local projects
  if [[ "$target" == "all" ]]; then
    projects=$(_read_projects)
  else
    projects=$(_get_project "$target")
    if [[ -z "$projects" ]]; then
      _err "Project '$target' not found in projects.conf"
      echo "  Available: $(_read_projects | cut -d'|' -f1 | tr '\n' ' ')"
      exit 1
    fi
  fi

  if [[ -z "$projects" ]]; then
    _warn "No projects configured. Add one with: matrix add <name> <path>"
    exit 0
  fi

  while IFS='|' read -r name path mode roles desc; do
    [[ -z "$name" ]] && continue
    path="${path/#~/$HOME}"

    if ! [[ -d "$path" ]]; then
      _warn "Skipping $name — directory not found: $path"
      continue
    fi

    if tmux has-session -t "$name" 2>/dev/null; then
      _info "$name — tmux session already exists"
      _launch_claude_in_session "$name" "$path" "$mode" "$roles"
      continue
    fi

    _info "Creating tmux session: ${BOLD}$name${NC}"

    if [[ "$mode" == "interactive" && -n "$roles" ]]; then
      # Interactive mode: one window per role
      local first=true
      IFS=',' read -ra role_list <<< "$roles"
      for role in "${role_list[@]}"; do
        role=$(echo "$role" | xargs)  # trim whitespace
        local session_name="${name}-${role}"
        if $first; then
          tmux new-session -d -s "$name" -n "$role" -c "$path"
          first=false
        else
          tmux new-window -t "$name" -n "$role" -c "$path"
        fi
        # Launch Claude in each window
        local rc_name="${name}-${role}"
        tmux send-keys -t "${name}:${role}" \
          "claude --remote-control '${rc_name}'" Enter
        _ok "  ${role} → claude --rc '${rc_name}'"
      done
      # Add a plain shell window for logs/misc
      tmux new-window -t "$name" -n "shell" -c "$path"
    else
      # Server mode: claude interactive + shell window
      tmux new-session -d -s "$name" -n "$name" -c "$path"
      tmux send-keys -t "${name}:${name}" "exec claude --dangerously-skip-permissions" Enter
      tmux new-window -t "$name" -n "${name} shell" -c "$path"
      # Set @desc session option for the top status bar
      if [[ -n "$desc" ]]; then
        tmux set-option -t "$name" @desc "$desc" 2>/dev/null
      fi
      # Prevent auto-rename from overriding our window names
      tmux set-option -t "$name" allow-rename off 2>/dev/null
      tmux set-option -t "$name" automatic-rename off 2>/dev/null
      _ok "$name → claude started"
    fi
  done <<< "$projects"

  echo ""
  cmd_list
}

_launch_claude_in_session() {
  local name="$1" path="$2" mode="$3" roles="$4"

  if [[ "$mode" == "interactive" && -n "$roles" ]]; then
    IFS=',' read -ra role_list <<< "$roles"
    for role in "${role_list[@]}"; do
      role=$(echo "$role" | xargs)
      # Check if Claude is already running in this window
      local pane_cmd
      pane_cmd=$(tmux display-message -t "${name}:${role}" -p '#{pane_current_command}' 2>/dev/null || echo "")
      if [[ "$pane_cmd" == "claude" ]]; then
        _info "  ${role} — Claude already running"
      else
        _warn "  ${role} — window exists but Claude not running. Start with:"
        echo "    tmux send-keys -t '${name}:${role}' 'claude --remote-control \"${name}-${role}\"' Enter"
      fi
    done
  else
    local pane_cmd
    pane_cmd=$(tmux display-message -t "${name}:rc" -p '#{pane_current_command}' 2>/dev/null || echo "")
    if [[ "$pane_cmd" == "claude" ]]; then
      _info "  rc — Claude already running"
    else
      _warn "  rc window exists but Claude not running. Restart with:"
      echo "    tmux send-keys -t '${name}:rc' 'exec claude --dangerously-skip-permissions' Enter"
    fi
  fi
}

cmd_down() {
  local target="${1:-}"

  if [[ -z "$target" ]]; then
    _warn "This will kill ALL matrix-managed tmux sessions."
    read -rp "Continue? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || exit 0

    for name in $(_read_projects | cut -d'|' -f1); do
      if tmux has-session -t "$name" 2>/dev/null; then
        tmux kill-session -t "$name"
        _ok "Killed session: $name"
      fi
    done
  else
    if tmux has-session -t "$target" 2>/dev/null; then
      tmux kill-session -t "$target"
      _ok "Killed session: $target"
    else
      _err "No tmux session named '$target'"
    fi
  fi
}

cmd_list() {
  echo -e "${BOLD}Matrix Sessions${NC}"
  echo -e "${DIM}─────────────────────────────────────────${NC}"

  local has_any=false

  while IFS='|' read -r name path mode roles desc; do
    [[ -z "$name" ]] && continue
    path="${path/#~/$HOME}"
    has_any=true

    if tmux has-session -t "$name" 2>/dev/null; then
      local status="${GREEN}● running${NC}"
      local windows
      windows=$(tmux list-windows -t "$name" -F '#{window_name}' 2>/dev/null | tr '\n' ' ')
      echo -e "  ${BOLD}${name}${NC}  ${status}  ${DIM}[${mode}]${NC}"
      if [[ -n "$desc" ]]; then
        echo -e "    ${CYAN}${desc}${NC}"
      fi
      echo -e "    ${DIM}path:${NC} $path"
      echo -e "    ${DIM}windows:${NC} $windows"
    else
      echo -e "  ${BOLD}${name}${NC}  ${DIM}○ stopped  [${mode}]${NC}"
      if [[ -n "$desc" ]]; then
        echo -e "    ${CYAN}${desc}${NC}"
      fi
      echo -e "    ${DIM}path:${NC} $path"
    fi
  done <<< "$(_read_projects)"

  if ! $has_any; then
    echo -e "  ${DIM}No projects configured. Add one with: matrix add <name> <path>${NC}"
  fi

  echo ""

  # Show any tmux sessions not managed by matrix
  local managed all_sessions=""
  managed=$(_read_projects | cut -d'|' -f1 | sort || true)
  if tmux list-sessions &>/dev/null; then
    all_sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | sort)
  fi

  if [[ -n "$all_sessions" ]]; then
    local unmanaged
    unmanaged=$(comm -23 <(echo "$all_sessions") <(echo "$managed") 2>/dev/null || true)
    if [[ -n "$unmanaged" ]]; then
      echo -e "${DIM}Other tmux sessions:${NC} $unmanaged"
    fi
  fi
}

cmd_attach() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    # If only one session, attach to it
    local count
    count=$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$count" -eq 1 ]]; then
      target=$(tmux list-sessions -F '#{session_name}' 2>/dev/null)
    else
      _err "Specify a session to attach to"
      echo "  Available: $(tmux list-sessions -F '#{session_name}' 2>/dev/null | tr '\n' ' ')"
      exit 1
    fi
  fi

  if tmux has-session -t "$target" 2>/dev/null; then
    exec tmux attach-session -t "$target"
  else
    _err "No tmux session named '$target'"
    exit 1
  fi
}

cmd_add() {
  local name="${1:-}"
  local path="${2:-}"
  local mode="${3:-server}"
  local roles="${4:-}"

  if [[ -z "$name" || -z "$path" ]]; then
    _err "Usage: matrix add <name> <path> [server|interactive] [role1,role2,...]"
    exit 1
  fi

  # Resolve path
  path="${path/#~/$HOME}"
  if [[ "$path" != /* ]]; then
    path="$(cd "$path" 2>/dev/null && pwd)" || {
      _err "Cannot resolve path: $path"
      exit 1
    }
  fi

  if ! [[ -d "$path" ]]; then
    _err "Directory not found: $path"
    exit 1
  fi

  # Check for duplicate
  if [[ -n "$(_get_project "$name")" ]]; then
    _err "Project '$name' already exists. Remove it first: matrix remove $name"
    exit 1
  fi

  # Ensure conf dir and file exist
  mkdir -p "$(dirname "$CONF")"
  touch "$CONF"

  # Use ~ shorthand for home dir in config
  local config_path="$path"
  config_path="${config_path/#$HOME/~}"

  echo "${name}|${config_path}|${mode}|${roles}" >> "$CONF"
  _ok "Added project: $name ($mode)"
  echo -e "  ${DIM}path:${NC} $path"
  if [[ -n "$roles" ]]; then
    echo -e "  ${DIM}roles:${NC} $roles"
  fi
  echo ""
  echo "  Start with: matrix up $name"
}

cmd_remove() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    _err "Usage: matrix remove <name>"
    exit 1
  fi

  if [[ -z "$(_get_project "$name")" ]]; then
    _err "Project '$name' not found"
    exit 1
  fi

  # Kill session if running
  if tmux has-session -t "$name" 2>/dev/null; then
    tmux kill-session -t "$name"
    _info "Killed tmux session: $name"
  fi

  # Remove from conf (macOS sed needs '' for -i)
  sed -i '' "/^${name}|/d" "$CONF"
  _ok "Removed project: $name"
}

cmd_quick() {
  # Quick one-off interactive session
  local name="${1:-quick}"
  local dir="${2:-$(pwd)}"

  _info "Starting quick interactive session: $name"
  _info "Directory: $dir"

  if tmux has-session -t "matrix-${name}" 2>/dev/null; then
    _warn "Session 'matrix-${name}' already exists. Attaching..."
    exec tmux attach-session -t "matrix-${name}"
  fi

  tmux new-session -d -s "matrix-${name}" -c "$dir"
  tmux send-keys -t "matrix-${name}" \
    "exec claude --dangerously-skip-permissions" Enter
  _ok "Session started. Attach with: matrix attach matrix-${name}"
}

cmd_restart() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    _err "Usage: matrix restart <project>"
    exit 1
  fi

  local project
  project=$(_get_project "$target")
  if [[ -z "$project" ]]; then
    _err "Project '$target' not found"
    exit 1
  fi

  _info "Restarting $target..."
  cmd_down "$target" 2>/dev/null || true
  sleep 1
  cmd_up "$target"
}

cmd_status() {
  echo -e "${BOLD}System Status${NC}"
  echo -e "${DIM}─────────────────────────────────────────${NC}"

  # Claude Code version
  local version
  version=$(claude --version 2>&1)
  echo -e "  Claude Code:  ${GREEN}$version${NC}"

  # ANTHROPIC_API_KEY
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    echo -e "  API Key:      ${YELLOW}set${NC}"
  else
    echo -e "  API Key:      ${DIM}not set (OAuth mode)${NC}"
  fi

  # tmux
  local tmux_ver
  tmux_ver=$(tmux -V 2>&1)
  echo -e "  tmux:         ${GREEN}$tmux_ver${NC}"

  # MATRIX_HOME
  echo -e "  MATRIX_HOME:  ${CYAN}$MATRIX_HOME${NC}"

  # matrix-app server
  local pid_file="${MATRIX_HOME}/matrix.pid"
  if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
    echo -e "  matrix-app:   ${GREEN}running (PID $(cat "$pid_file"))${NC}"
  else
    echo -e "  matrix-app:   ${DIM}not running${NC}"
  fi

  # Active sessions
  local count=0
  if tmux list-sessions &>/dev/null; then
    count=$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')
  fi
  echo -e "  tmux sessions: ${CYAN}$count${NC}"

  echo ""
}

cmd_describe() {
  local name="${1:-}"
  shift 2>/dev/null || true
  local desc="$*"

  if [[ -z "$name" ]]; then
    _err "Usage: matrix describe <project> <description>"
    exit 1
  fi

  if [[ -z "$(_get_project "$name")" ]]; then
    _err "Project '$name' not found"
    exit 1
  fi

  if [[ -z "$desc" ]]; then
    # Show current description
    local line
    line=$(_get_project "$name")
    local current_desc
    current_desc=$(echo "$line" | cut -d'|' -f5)
    if [[ -n "$current_desc" ]]; then
      echo -e "  ${BOLD}$name${NC}: $current_desc"
    else
      echo -e "  ${BOLD}$name${NC}: ${DIM}(no description)${NC}"
    fi
    return
  fi

  # Update the description (5th field) in projects.conf
  local line
  line=$(_get_project "$name")
  local proj_path mode roles
  proj_path=$(echo "$line" | cut -d'|' -f2)
  mode=$(echo "$line" | cut -d'|' -f3)
  roles=$(echo "$line" | cut -d'|' -f4)

  # Build new line and replace using grep -n + sed by line number
  local new_line="${name}|${proj_path}|${mode}|${roles}|${desc}"
  local line_num
  line_num=$(grep -n "^${name}|" "$CONF" | head -1 | cut -d: -f1)
  if [[ -n "$line_num" ]]; then
    sed -i '' "${line_num}s|.*|${new_line}|" "$CONF"
    _ok "Description updated for $name"
  else
    _err "Could not find $name in projects.conf"
  fi
}

cmd_rename_sessions() {
  # Rename numbered tmux sessions to meaningful names based on scrollback content
  _info "Scanning numbered sessions for project context..."

  local renamed=0
  for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null); do
    # Only target numbered sessions
    [[ "$session" =~ ^[0-9]+$ ]] || continue

    # Try to infer project from scrollback
    local inferred=""
    local scrollback
    scrollback=$(tmux capture-pane -t "${session}:0" -p -S -500 2>/dev/null || echo "")

    if [[ -n "$scrollback" ]]; then
      # Look for project directory references in scrollback
      inferred=$(echo "$scrollback" | grep -oE '(~|/Users/[a-zA-Z0-9_]+)/(Desktop|Projects|Downloads)/[a-zA-Z0-9_-]+' | \
        sed 's|.*/||' | sort | uniq -c | sort -rn | head -1 | awk '{print $2}' || true)
    fi

    if [[ -z "$inferred" ]]; then
      # Try pane current path
      local pane_path
      pane_path=$(tmux display-message -t "$session" -p '#{pane_current_path}' 2>/dev/null || echo "")
      if [[ -n "$pane_path" && "$pane_path" != "$HOME" ]]; then
        inferred=$(basename "$pane_path")
      fi
    fi

    if [[ -n "$inferred" ]]; then
      # Avoid collision with existing session names
      local new_name="$inferred"
      local suffix=1
      while tmux has-session -t "$new_name" 2>/dev/null && [[ "$new_name" != "$session" ]]; do
        new_name="${inferred}-${suffix}"
        ((suffix++))
      done

      if [[ "$new_name" != "$session" ]]; then
        tmux rename-session -t "$session" "$new_name" 2>/dev/null && {
          _ok "Renamed $session → $new_name"
          ((renamed++))
        }
      fi
    else
      _warn "Session $session — could not infer project name"
    fi
  done

  if [[ $renamed -eq 0 ]]; then
    _info "No sessions to rename"
  else
    _ok "Renamed $renamed session(s)"
  fi
}

cmd_help() {
  cat <<'HELP'
matrix — Matrix session manager

USAGE
  matrix <command> [args]

SESSION COMMANDS
  up [project]        Start Claude sessions (all projects or specific one)
  down [project]      Stop sessions (all or specific)
  restart <project>   Stop and restart a project
  attach <project>    Attach to a project's tmux session
  list                List all projects and their status
  quick [name] [dir]  Start a one-off interactive session
  rename              Rename numbered sessions to project folder names

PROJECT COMMANDS
  add <name> <path> [mode] [roles]
                      Add a project (mode: server|interactive)
  remove <name>       Remove a project
  describe <name> [description]
                      Set or show a project's description

SYSTEM COMMANDS
  status              Show system health and dependencies
  help                Show this help

EXAMPLES
  matrix add myproject ~/Projects/myproject server
  matrix describe myproject "My Claude Code project"
  matrix up                         # Start all projects
  matrix up myproject               # Start one project
  matrix rename                     # Fix numbered session names
  matrix quick hotfix ~/tmp/fix     # Quick one-off session
  matrix attach myproject           # Jump into tmux session
  matrix down myproject             # Stop one project
  matrix down                       # Stop all (with confirmation)

ENVIRONMENT
  MATRIX_HOME   Base directory for config and logs (default: ~/.matrix)

ARCHITECTURE
  Server mode:      One Claude process per project session
  Interactive mode: One Claude process per role (planner, builder, etc.)
HELP
}

# ── Dispatch ───────────────────────────────────────────────────────────

case "${1:-help}" in
  up)       shift; cmd_up "$@" ;;
  down)     shift; cmd_down "$@" ;;
  list|ls)  cmd_list ;;
  attach|a) shift; cmd_attach "$@" ;;
  add)      shift; cmd_add "$@" ;;
  remove|rm) shift; cmd_remove "$@" ;;
  describe|desc) shift; cmd_describe "$@" ;;
  rename)   cmd_rename_sessions ;;
  quick|q)  shift; cmd_quick "$@" ;;
  restart)  shift; cmd_restart "$@" ;;
  status|s) cmd_status ;;
  help|-h|--help) cmd_help ;;
  *)
    _err "Unknown command: $1"
    echo "  Run 'matrix help' for usage"
    exit 1
    ;;
esac
